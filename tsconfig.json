{
    "compilerOptions": {
        "esModuleInterop": true,
        "exactOptionalPropertyTypes": true,
        "lib": [
            "ES2022"
        ],
        "module": "CommonJS",
        "moduleResolution": "Node10",
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "rootDir": ".",
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2022"
    },
    "exclude": [
        "node_modules",
        "dist",
        "cv-api"
    ],
    "include": [
        "scripts/**/*.ts"
    ]
}
