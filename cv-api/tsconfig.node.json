{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "module": "CommonJS",
        "moduleResolution": "Node10",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "esModuleInterop": true,
        "types": ["node", "vitest/globals"]
    },
    "include": ["lib/**/*.ts", "local/**/*.ts", "__tests__/**/*.ts"]
}
